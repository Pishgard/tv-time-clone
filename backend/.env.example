# ===== Django core =====
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ===== Database =====
# SQLite is used by default (no extra setup needed).
# To use PostgreSQL, uncomment and fill these:
# DATABASE_URL=postgres://user:password@localhost:5432/tvtime

# ===== CORS =====
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== JWT =====
JWT_ACCESS_LIFETIME_MINUTES=15
JWT_REFRESH_LIFETIME_DAYS=7

# ===== TMDB =====
# Get a free key from https://www.themoviedb.org/settings/api
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
